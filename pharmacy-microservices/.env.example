# ==================================================================
# .env.example — modelo de variáveis de ambiente
# ==================================================================
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
# O arquivo .env NUNCA deve ser commitado (está no .gitignore).
# ==================================================================

# --- Product Service ---
PRODUCT_SERVICE_PORT=8001
PRODUCT_DATABASE_URL=sqlite:///./data/products.db

# --- Inventory Service ---
INVENTORY_SERVICE_PORT=8002
INVENTORY_DATABASE_URL=sqlite:///./data/inventory.db
ESTOQUE_MINIMO_PADRAO=10

# --- Sales Service ---
SALES_SERVICE_PORT=8003
SALES_DATABASE_URL=sqlite:///./data/sales.db

# --- API Gateway ---
API_GATEWAY_PORT=8000

# --- URLs internas (usadas quando roda local, sem Docker) ---
PRODUCT_SERVICE_URL=http://localhost:8001
INVENTORY_SERVICE_URL=http://localhost:8002
SALES_SERVICE_URL=http://localhost:8003
