# Portal Cartorial — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório!

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=portal_cartorial
POSTGRES_USER=cartorial
POSTGRES_PASSWORD=cartorial_secret_change_me

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me

# ── MinIO (S3-compatible) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_change_me
MINIO_BUCKET_DOCUMENTS=documentos

# ── Keycloak ────────────────────────────────────────────────────────────────
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin_secret_change_me
KC_CLIENT_ID=portal-api
KC_CLIENT_SECRET=client_secret_change_me
KC_WEB_CLIENT_ID=portal-web
KC_WEB_CLIENT_SECRET=web_client_secret_change_me

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_CHANGE_IN_PRODUCTION_min_32_chars

# ── Next.js / NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=nextauth_secret_change_me
NEXT_PUBLIC_API_URL=http://localhost:3000
